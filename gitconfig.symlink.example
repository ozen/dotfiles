[user]
	name = Yigit Ozen
	email = AUTHOREMAIL
[core]
	editor = vim
[merge]
	tool = vimdiff
[credential]
	helper = cache --timeout=3600
[push]
	default = matching
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
[rebase]
	autoStash = true
